# Required: OpenRouter API key
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Optional: HTTP proxy (uncomment if you need to route through a proxy)
# Examples:
#   HTTPS_PROXY=http://127.0.0.1:7890        # local Clash / V2RayN / sing-box
#   HTTPS_PROXY=socks5://127.0.0.1:1080      # SOCKS5
#   HTTPS_PROXY=http://user:pass@host:8080  # with auth
# HTTPS_PROXY=http://127.0.0.1:7890
