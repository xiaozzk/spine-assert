# OPENROUTER_API_KEY is configured as a SYSTEM-LEVEL environment variable,
# NOT in this .env file. Set it via:
#
#   PowerShell:
#     [Environment]::SetEnvironmentVariable("OPENROUTER_API_KEY", "sk-or-v1-...", "User")
#   CMD:
#     setx OPENROUTER_API_KEY "sk-or-v1-..."
#
# Then open a new terminal so the env propagates.

# Optional: HTTP proxy (uncomment if you need to route through a proxy)
# Examples:
#   HTTPS_PROXY=http://127.0.0.1:7890        # local Clash / V2RayN / sing-box
#   HTTPS_PROXY=socks5://127.0.0.1:1080      # SOCKS5
#   HTTPS_PROXY=http://user:pass@host:8080   # with auth
# HTTPS_PROXY=http://127.0.0.1:7890
